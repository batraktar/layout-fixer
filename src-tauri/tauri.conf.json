{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Layout Fixer",
  "version": "0.1.0",
  "identifier": "com.batraktar.layout-fixer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Layout Fixer",
        "width": 820,
        "height": 720,
        "minWidth": 520,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}


{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Layout Fixer",
  "version": "0.1.0",
  "identifier": "com.batraktar.layout-fixer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Layout Fixer",
        "width": 600,
        "height": 650,
        "minWidth": 460,
        "minHeight": 560,
        "resizable": true,
        "visible": false,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
